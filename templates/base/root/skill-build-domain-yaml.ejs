## Paso 2 — Estructura completa del domain.yaml

```yaml
aggregates:
  - name: Order                         # PascalCase — nombre del agregado
    entities:
      - name: order                     # camelCase — nombre de la entidad
        isRoot: true                    # true para la raíz del agregado
        tableName: orders               # snake_case — nombre de tabla SQL
        hasSoftDelete: false            # true para borrado lógico (deletedAt)
        audit:
          enabled: true                 # agrega createdAt, updatedAt
          trackUser: false              # agrega createdBy, updatedBy
        fields:
          - name: id
            type: String
          - name: orderNumber
            type: String
            validations:
              - type: NotBlank
                message: "Número de pedido requerido"
          - name: totalAmount
            type: BigDecimal
            readOnly: true              # calculado — no en CreateDto ni constructor de negocio
            defaultValue: "0.00"        # valor inicial en constructor de creación
          - name: status
            type: OrderStatus
            readOnly: true              # gestionado por transitions
          - name: processingToken
            type: String
            hidden: true                # sensible — no en ResponseDto
          - name: customerId
            type: String
            reference:
              aggregate: Customer       # PascalCase
              module: customers         # módulo donde vive
        relationships:
          - type: OneToMany             # OneToOne | OneToMany | ManyToOne
            target: OrderItem
            mappedBy: order
            cascade: [PERSIST, MERGE, REMOVE]
            fetch: LAZY

      - name: orderItem                 # entidad secundaria — isRoot omitido (false por defecto)
        tableName: order_items
        fields:
          - name: id
            type: String
          - name: productId
            type: String
          - name: quantity
            type: Integer
            validations:
              - type: Min
                value: 1
          - name: unitPrice
            type: BigDecimal
        # No declarar ManyToOne hacia Order — el generador lo infiere automáticamente
        # desde la relación OneToMany declarada en la entidad raíz

    valueObjects:
      - name: ShippingAddress           # PascalCase — inmutable, sin ID
        fields:
          - name: street
            type: String
          - name: city
            type: String
          - name: zipCode
            type: String
        methods:                        # opcional — lógica de negocio del VO
          - name: format
            returnType: String
            parameters: []
            body: "return street + \", \" + city + \" \" + zipCode;"

    enums:
      - name: OrderStatus
        initialValue: PENDING           # estado inicial — excluido del CreateDto
        transitions:
          - from: PENDING
            to: CONFIRMED
            method: confirm
          - from: CONFIRMED
            to: SHIPPED
            method: ship
          - from: [PENDING, CONFIRMED]  # múltiples orígenes
            to: CANCELLED
            method: cancel
            guard: "this.status == OrderStatus.DELIVERED"  # lanza BusinessException si se cumple
        values: [PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED]

    events:
      - name: OrderConfirmedEvent       # PascalCase, tiempo pasado, sufijo Event
        fields:
          - name: orderId
            type: String
          - name: confirmedAt
            type: LocalDateTime

endpoints:                              # Opcional — solo si system/system.yaml ya declara exposes: para este módulo
  basePath: /orders
  versions:
    - version: v1
      operations:
        - useCase: GetOrder             # debe coincidir con system/system.yaml → exposes[].useCase
          method: GET
          path: /{id}                   # relativo al basePath
        - useCase: FindAllOrders
          method: GET
          path: /
        - useCase: CreateOrder
          method: POST
          path: /
        - useCase: ConfirmOrder         # nombre de negocio → genera scaffold
          method: PUT
          path: /{id}/confirm

# Listeners: eventos externos que CONSUME este módulo
# Inferidos de system/system.yaml → integrations.async[].consumers[] donde module = este módulo
listeners:
  - event: PaymentApprovedEvent         # debe coincidir con integrations.async[].event
    producer: payments                  # módulo origen (referencia documental)
    topic: PAYMENT_APPROVED             # debe coincidir con integrations.async[].topic
    useCase: ConfirmOrder               # debe coincidir con consumers[].useCase
    fields:
      - name: orderId
        type: String
      - name: approvedAt
        type: LocalDateTime
      - name: paymentDetails            # tipo objeto → DEBE declararse en nestedTypes:
        type: PaymentDetails
    nestedTypes:                        # un entry por cada tipo objeto en fields:
      - name: paymentDetails            # camelCase → record PaymentDetails en application/events/
        fields:                         # compartido por IntegrationEvent, Command y KafkaListener
          - name: paymentId
            type: String
          - name: amount
            type: BigDecimal

# Ports: servicios HTTP síncronos que LLAMA este módulo (un entry por endpoint HTTP)
# Inferidos de system/system.yaml → integrations.sync[] donde caller = este módulo
ports:
  - name: findCustomerById              # camelCase — derivado del endpoint
    service: CustomerService            # debe coincidir con integrations.sync[].port
    target: customers                   # módulo destino
    baseUrl: http://localhost:8080      # solo en la primera entrada de cada service
    http: GET /customers/{id}           # debe coincidir con integrations.sync[].using[]
    fields:
      - name: id
        type: String
      - name: email
        type: String
  - name: findAvailableSeats            # segunda entrada del mismo service — sin baseUrl
    service: CustomerService
    target: customers
    http: GET /customers/{id}/available-seats
    returnList: true                    # retorna List<>
    domainType: Seat                    # auto-deriva "AvailableSeat" → override a "Seat"
    fields:
      - name: seatId
        type: String
      - name: seatType
        type: String
  - name: processPayment                # entrada de otro service — POST con body:
    service: PaymentGateway
    target: payments
    baseUrl: https://api.payments.example.com
    http: POST /payments
    body:                               # @RequestBody — solo POST/PUT/PATCH
      - name: reservationId
        type: String
      - name: paymentMethod
        type: PaymentMethodInput        # tipo objeto en el body → declarar en nestedTypes:
    nestedTypes:                        # genera PaymentMethodInput.java en application/dtos/
      - name: paymentMethodInput        # camelCase → normalizado a PaymentMethodInput
        fields:
          - name: type
            type: String
          - name: cardToken
            type: String
    fields:                             # respuesta del POST
      - name: paymentId
        type: String
      - name: status
        type: String
```

